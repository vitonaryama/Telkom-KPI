# ============================================================================
# KONFIGURASI DATABASE
# Salin file ini ke .env dan isi sesuai environment Anda
# JANGAN commit file .env ke git!
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kpi_witel_pekalongan

# ============================================================================
# KONFIGURASI SERVER
# ============================================================================
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

# ============================================================================
# KONFIGURASI JWT
# WAJIB diganti ke string random minimal 32 karakter sebelum production!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================
JWT_SECRET=GANTI_INI_DENGAN_STRING_RANDOM_MIN_32_KARAKTER
JWT_EXPIRES=24h

# ============================================================================
# KONFIGURASI UPLOAD
# ============================================================================
MAX_FILE_SIZE=26214400
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=csv

# ============================================================================
# KONFIGURASI EMAIL (untuk fitur forgot password)
# Gunakan SMTP Gmail/Outlook atau layanan seperti Mailtrap untuk development
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@telkom.co.id

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
