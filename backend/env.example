# ============================================================================
# KONFIGURASI DATABASE
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kpi_witel_pekalongan

# ============================================================================
# KONFIGURASI SERVER
